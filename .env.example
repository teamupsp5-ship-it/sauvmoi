# ── IA (optionnel) ────────────────────────────────────────────────────────────
# Sans clé, le chat utilise les protocoles PSC1 embarqués (mode hors-ligne).
# Sur Railway : Settings → Variables → ajouter ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Serveur ────────────────────────────────────────────────────────────────────
# Railway injecte PORT automatiquement — ne pas le définir manuellement en prod.
PORT=3000
